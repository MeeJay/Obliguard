<!--
  WinSW config for Obliguard Agent.
  This file is installed alongside ObliguardService.exe (WinSW) in the install folder.
  The <arguments> element is rewritten at install time by the MSI (WiX util:XmlConfig).
-->
<service>
  <id>ObliguardAgent</id>
  <name>Obliguard Monitoring Agent</name>
  <description>Sends system metrics to the Obliguard monitoring platform.</description>
  <executable>%BASE%\obliguard-agent.exe</executable>
  <arguments>--url "" --key ""</arguments>
  <onfailure action="restart" delay="10 sec"/>
  <onfailure action="restart" delay="30 sec"/>
  <onfailure action="restart" delay="60 sec"/>
  <log mode="none"/>
</service>
